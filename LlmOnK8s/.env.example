# 项目环境变量配置模板（公开仓库脱敏版）

## 阿里云通用配置
export ALIYUN_REGION=请填写阿里云地域代码
export ALIYUN_ACCESS_KEY_ID=请填写阿里云访问密钥ID
export ALIYUN_ACCESS_KEY_SECRET=请填写阿里云访问密钥Secret

## 容器镜像仓库(ACR)配置
export ALIYUN_REGISTRY=请填写阿里云镜像仓库地址
export ALIYUN_NAMESPACE=请填写镜像仓库命名空间
export ACR_WEBAPP_REPO=请填写Web应用仓库名称
export ACR_INFERENCE_REPO=请填写推理服务仓库名称
export ALIYUN_REGISTRY_USERNAME=请填写镜像仓库登录用户名
export ALIYUN_REGISTRY_PASSWORD=请填写镜像仓库登录密码

## 容器服务(ACK)集群配置
export ACK_CLUSTER_ID=请填写ACK集群ID
export ACK_CLUSTER_NAME=请填写ACK集群名称

## 镜像构建配置
export IMAGE_TAG=latest
export DOCKER_BUILDKIT=1

## 模型配置
export MODEL_ID=请填写模型ID
export MODEL_DISPLAY_NAME=请填写模型显示名称
export MODEL_SOURCE=hf
export MODEL_OSS_URI=请填写OSS模型路径
export MODEL_LOCAL_PATH=/models/local-model
export HF_TOKEN=请填写HuggingFace令牌

## 推理服务配置
export GPU_MEMORY_UTILIZATION=0.92
export MAX_MODEL_LEN=8192
export VLLM_DTYPE=bfloat16

## 租户配置
export TENANT_A_TOKEN=请填写租户A令牌
export TENANT_B_TOKEN=请填写租户B令牌

## API 模式配置（如需启用）
export VLLM_API_URL=请填写OpenAI兼容API地址
export VLLM_API_TOKEN=请填写OpenAI兼容API令牌
export VLLM_MODEL_NAME=请填写API模型名称

## 日志和调试
export LOG_LEVEL=INFO
export INFERENCE_TIMEOUT_SECONDS=180
